    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@roamcli/agent-claude-code": "workspace:*",
    "@roamcli/agent-codex": "workspace:*",
    "@types/react": "^19.2.16",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
